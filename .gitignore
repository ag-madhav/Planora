# --- 1. THE AI "SHIELD" ---
# This ignores every folder starting with a dot (like .adal, .roo, .claude)
.*
# But we MUST keep these specific important files
!/.gitignore
!/.github
!/.git
!/client
!/backend

# --- 2. DEPENDENCIES ---
# Keeps the heavy library folders off GitHub
node_modules/
**/node_modules/

# --- 3. PRODUCTION BUILDS ---
# Ignores the "translated" code folders created by Vite
dist/
**/dist/
build/
.cache/

# --- 4. SECURITY ---
# Prevents your Gemini API Keys from being stolen
.env
.env.*
firebase-debug.log*
.firebase/

# --- 5. SPECIFIC JUNK ---
# Cleans up the other AI metadata files
skills/
skills-lock.json